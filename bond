#!/usr/bin/env bash
# bond — Check your AGON bonding level, XP, and stats (via programmable audit)
set -euo pipefail

AUDIT_SCRIPT="${HOME}/.hermes/agon/bond-audit.py"
BONDING_PY="${HOME}/.hermes/agon/bonding.py"

if [ ! -f "$AUDIT_SCRIPT" ]; then
    echo "  AGON audit script not found. Run 'install.sh' first."
    exit 1
fi

# Run audit to ensure stats are current, then display
python3 "$AUDIT_SCRIPT" > /dev/null 2>&1 || true

if [ -f "$BONDING_PY" ]; then
    cd "$HOME/.hermes/agon" && python3 -c "
from bonding import format_level, load_bonding
print(format_level(load_bonding()))
"
else
    # Fallback: raw JSON display
    python3 -c "
import json
with open('${HOME}/.hermes/agon/bonding.json') as f:
    b = json.load(f)
print('')
print('  AGON — BOND STATUS')
print(f'  Level:  {b[\"level\"]}')
print(f'  XP:     {b[\"cumulative_xp\"]}')
next_xp = 10 * (b['level'] + 1) ** 2 + 5
print(f'  Next:   {next_xp - b[\"cumulative_xp\"]} XP')
print('')
print('  DEUS VULT.')
"
fi
